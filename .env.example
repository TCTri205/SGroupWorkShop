# SGroup MCP Server - Environment Variables
# Sao ch’┐Įp file n’┐Įy th’┐Įnh .env v’┐Į ’┐Įi?n API keys th?t v’┐Įo

# Google AI Studio (Gemini) - bat buoc neu muon LangGraph route/synthesize bang LLM
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_TIMEOUT_MS=8000

# OpenWeather API - https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Exa Search API - https://docs.exa.ai
EXA_API_KEY=your_exa_api_key_here

# NewsAPI - https://newsapi.org (tuy chon, dung RSS neu khong co key)
NEWS_API_KEY=your_newsapi_key_here

# Brave Search - https://api.search.brave.com/app/dashboard (2000 free requests/month)
BRAVE_API_KEY=your_brave_api_key_here

# ngrok - https://dashboard.ngrok.com/get-started/your-authtoken
# Dung de cau hinh `ngrok config add-authtoken` hoac script public URL sau nay
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# GitHub - https://github.com/settings/tokens (Personal Access Token)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# Context7 - https://context7.com/dashboard (Optional, for higher rate limits)
# CONTEXT7_API_KEY=your_context7_api_key_here
